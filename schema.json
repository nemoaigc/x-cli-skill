{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nemoaigc/x-cli/blob/main/schema.json",
  "title": "x-cli envelope",
  "description": "All x-cli scripts emit either a success or an error envelope on stdout. This file formalizes both shapes.",
  "oneOf": [
    {"$ref": "#/$defs/success"},
    {"$ref": "#/$defs/error"}
  ],
  "$defs": {
    "success": {
      "type": "object",
      "required": ["ok", "schema_version", "data"],
      "properties": {
        "ok": {"const": true},
        "schema_version": {"const": "1"},
        "data": {
          "description": "Payload type depends on the calling script. Common shapes: list of tweet objects, single profile object, dict with `kols`/`tweets`, etc."
        }
      },
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": ["ok", "schema_version", "error"],
      "properties": {
        "ok": {"const": false},
        "schema_version": {"const": "1"},
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "string",
              "description": "Machine-readable error code",
              "examples": [
                "invalid_input",
                "not_authenticated",
                "rate_limit",
                "not_found",
                "api_error",
                "network_error",
                "startup_error",
                "write_failed",
                "unexpected_error"
              ]
            },
            "message": {
              "type": "string",
              "description": "Human-readable error message"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "tweet": {
      "type": "object",
      "description": "Shape of an individual tweet returned by read.py / me.py / digest.py.",
      "required": ["id", "text", "author", "metrics", "created_at"],
      "properties": {
        "id": {"type": "string"},
        "text": {"type": "string"},
        "author": {
          "type": "object",
          "properties": {
            "id": {"type": "string"},
            "name": {"type": "string"},
            "screen_name": {"type": "string"}
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "likes": {"type": "integer"},
            "retweets": {"type": "integer"},
            "replies": {"type": "integer"},
            "views": {"type": ["integer", "null"]},
            "bookmarks": {"type": ["integer", "null"]}
          }
        },
        "created_at": {"type": "string"},
        "is_article": {"type": "boolean"},
        "is_note_tweet": {"type": "boolean"},
        "article_title": {"type": ["string", "null"]},
        "article_text": {"type": ["string", "null"]},
        "urls": {"type": "array", "items": {"type": "string"}}
      }
    },
    "write_action": {
      "type": "object",
      "description": "Shape of write.py success payload. The `action` field discriminates the variant.",
      "required": ["action"],
      "properties": {
        "action": {"enum": ["post", "delete", "follow", "unfollow"]},
        "tweet_id": {"type": "string"},
        "url": {"type": "string"},
        "text": {"type": "string"},
        "handle": {"type": "string"},
        "user_id": {"type": "string"},
        "following": {"type": "boolean"},
        "deleted": {"type": "boolean"},
        "dry_run": {"type": "boolean"},
        "plan": {"type": "object"},
        "hint": {"type": "string"}
      }
    }
  }
}
